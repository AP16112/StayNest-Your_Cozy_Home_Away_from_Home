<!-- Here this is a new view or template which is used to show all listings-->

<!-- Here we are making use of Ejs-Mate layouts, so here we are actually extending & inplementing the boilerplate.ejs code here -->

<%# It tells EJS-mate: “Use the layout file located at /views/layouts/boilerplate.ejs as the base template for this page.” %>
<%# Everything written after that <body> tag line becomes the child content that will be injected into the layout’s i.e boilerplate body placeholder. %>
<% layout("/layouts/boilerplate") %>     <%# It is an EJS-mate directive. %>
<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
    }
</style>

<body>
    <!-- <h3>All Listings</h3> -->

    <!-- Now no need of this button, as we can create new listing using navbar directly -->
    <!-- <form method="GET"  action="/listings/new">
        <button>Create New Listing</button>
    </form> -->

    <div id="filters">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i> </div>
            <p>Trending</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i> </div>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i> </div>
            <p>Iconic Cities</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i> </div>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i> </div>
            <p>Castles</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i> </div>
            <p>Amazing Pools</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-cow"></i> </div>
            <p>Farms</p>
        </div>
        <div class="filter">
            <div><i class="fa-regular fa-snowflake"></i> </div>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-igloo"></i> </div>
            <p>Domes</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-sailboat"></i> </div>
            <p>Boats</p>
        </div>

        <!-- Here we will use bootstrap Switch, which is actually a toggle button or checkbox only. -->
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    <!-- Here we will now style this index.ejs page using bootstrap cards -->

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings){ %>
        <a href="/listings/<%=listing._id%>"  class="listing-link">
            <div class="card col listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"  style="height: 20rem;">
                
                <!-- It is used to write some text or to do something over the image of the card like changing the opacity of color on hovering-->
                <div class="card-img-overlay"></div>

                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %> </b>  <br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                        <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
                    </p>
                </div>
            </div>
        </a>
        <% } %>
    </div>


    <!-- Here now we don't need this as we already showing everything using these above cards -->
    <!-- <ul> -->
    <!-- < % for(let listing of allListings){ %> -->
        <!-- Here it will give error because we are using colon (:) here, But colon is only required in backend part but here this is a link i.e URL i.e frontend part, so no need of colon here -->
        <!-- <a href="http://localhost:8080/listings/:< %=listing._id%>"></a> -->
        <!-- Now this is correct way -->
        <!-- This uses the full absolute URL (http://localhost:8080/...). It will always point to your local server running on port 8080, regardless of where the link is clicked. -->
        <!-- Useful if you’re testing locally and want to be explicit, but not ideal once you deploy (because localhost:8080 won’t exist for real users). -->
        <!-- <li><a href="http://localhost:8080/listings/< %=listing._id%>">< %= listing.title %></a></li> -->
        <!-- ------------OR-------------- -->
        <!-- This uses a relative path. It assumes our app is running on the same domain and port, so it just appends /listings/<id> to the current host. -->
        <!-- This is the preferred way in Express/EJS apps, because it works both locally and in production (e.g., on Heroku, Vercel, or any server). -->
        <!-- <li><a href="/listings/< %=listing._id%>">< %= listing.title %></a></li> -->
    <!-- < % } %> -->
    </ul>
</body>

<!-- Here currently, we are writing the JS & css code here only but if we want we can also write this in public folder & then can use it here -->
<script>
    let taxSwitch = document.getElementById("switchCheckDefault");

    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        
        for(let info of taxInfo){
            if(info.style.display !== "inline"){
                info.style.display = "inline";
            }else{
                info.style.display = "none";
            }
        }
    });
</script>